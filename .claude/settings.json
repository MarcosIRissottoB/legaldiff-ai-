{
  "permissions": {
    "allow": ["Read", "Glob", "Grep", "Bash(git log:*)", "Bash(git diff:*)"]
  },
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/format.sh" }]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/run-related-tests.sh", "async": true }]
      }
    ]
  }
}
